<Project>
  <PropertyGroup>
    <BaoBaoPaddleOCRAutoDownloadModels Condition="'$(BaoBaoPaddleOCRAutoDownloadModels)' == ''">true</BaoBaoPaddleOCRAutoDownloadModels>
    <BaoBaoPaddleOCRModelTargetDir Condition="'$(BaoBaoPaddleOCRModelTargetDir)' == ''">$(TargetDir)models</BaoBaoPaddleOCRModelTargetDir>
    <BaoBaoPaddleOCRModelSetupScript>$(MSBuildThisFileDirectory)tools\SetupModels.ps1</BaoBaoPaddleOCRModelSetupScript>
    <BaoBaoPaddleOCRModelReadyMarker>$(BaoBaoPaddleOCRModelTargetDir)\PP-OCRv5_server_rec_infer\inference.json</BaoBaoPaddleOCRModelReadyMarker>
  </PropertyGroup>

  <Target
    Name="BaoBaoPaddleOCR_AutoDownloadModels"
    AfterTargets="Build"
    Condition="'$(BaoBaoPaddleOCRAutoDownloadModels)' == 'true' and '$(OS)' == 'Windows_NT' and Exists('$(BaoBaoPaddleOCRModelSetupScript)') and !Exists('$(BaoBaoPaddleOCRModelReadyMarker)')">
    <Exec
      Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(BaoBaoPaddleOCRModelSetupScript)&quot; -ModelRoot &quot;$(BaoBaoPaddleOCRModelTargetDir)&quot;"
      WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>
</Project>
